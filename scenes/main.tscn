theme_override_font_sizes/font_size = 20
text = "WASD или стрелки — движение\nМышь — направление взгляда\nЛевая кнопка мыши — одиночный выстрел\nПравая кнопка мыши — поставить или убрать выбранный объект на соседней клетке\nКолесо мыши — выбрать дверь или турель\nE — открыть или закрыть дверь, взаимодействовать со станцией\nTab — открыть или закрыть карту\nПравая кнопка мыши на карте — указать или убрать точку маршрута\nEsc — пауза или вернуться назад"
horizontal_alignment = 1
line_spacing = 8

