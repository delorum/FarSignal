[node name="ControlsScreen" type="VBoxContainer" parent="CenterContainer"]
visible = false
custom_minimum_size = Vector2(560, 0)
layout_mode = 2
theme_override_constants/separation = 16

[node name="Title" type="Label" parent="CenterContainer/ControlsScreen"]
layout_mode = 2
theme_override_colors/font_color = Color(0.345, 0.839, 0.961, 1)
theme_override_font_sizes/font_size = 38
text = "Управление"
horizontal_alignment = 1

[node name="TitleSeparator" type="Control" parent="CenterContainer/ControlsScreen"]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2
mouse_filter = 2

[node name="Description" type="Label" parent="CenterContainer/ControlsScreen"]
layout_mode = 2
theme_override_colors/font_color = Color(0.82, 0.88, 0.94, 1)
theme_override_font_sizes/font_size = 20
text = "WASD или стрелки — движение\nМышь — направление взгляда\nЛевая кнопка мыши — выстрел\nПравая кнопка мыши — поставить или убрать дверь на соседней клетке\nЛевый Shift — режим засады\nE — открыть или закрыть дверь, взаимодействовать со станцией\nTab — открыть или закрыть карту\nПравая кнопка мыши на карте — указать или убрать точку маршрута\nКолесо мыши — масштаб карты\nEsc — пауза или вернуться назад"
horizontal_alignment = 1
line_spacing = 8

[node name="DescriptionSeparator" type="Control" parent="CenterContainer/ControlsScreen"]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2
mouse_filter = 2

[node name="BackButton" type="Button" parent="CenterContainer/ControlsScreen"]
custom_minimum_size = Vector2(0, 52)
layout_mode = 2
theme_override_font_sizes/font_size = 22
text = "Назад"

[connection signal="pressed" from="CenterContainer/MainMenu/NewGameButton" to="." method="_on_new_game_pressed"]
[connection signal="pressed" from="CenterContainer/MainMenu/ContinueButton" to="." method="_on_continue_pressed"]
[connection signal="pressed" from="CenterContainer/MainMenu/ControlsButton" to="." method="_on_controls_pressed"]
[connection signal="pressed" from="CenterContainer/MainMenu/ExitButton" to="." method="_on_exit_pressed"]
[connection signal="pressed" from="CenterContainer/ControlsScreen/BackButton" to="." method="_on_back_pressed"]
