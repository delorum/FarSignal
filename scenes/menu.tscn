layout_mode = 2
mouse_filter = 2

[node name="Description" type="Label" parent="CenterContainer/ControlsScreen"]
layout_mode = 2
theme_override_colors/font_color = Color(0.82, 0.88, 0.94, 1)
theme_override_font_sizes/font_size = 20
text = "WASD или стрелки — движение\nМышь — направление взгляда\nЛевая кнопка мыши — выстрел\nПравая кнопка мыши — поставить или убрать дверь на соседней клетке\nE — открыть или закрыть дверь, взаимодействовать со станцией\nTab — открыть или закрыть карту\nПравая кнопка мыши на карте — указать или убрать точку маршрута\nEsc — пауза или вернуться назад"
horizontal_alignment = 1
line_spacing = 8

[node name="DescriptionSeparator" type="Control" parent="CenterContainer/ControlsScreen"]
custom_minimum_size = Vector2(0, 20)
layout_mode = 2
mouse_filter = 2

[node name="BackButton" type="Button" parent="CenterContainer/ControlsScreen"]
custom_minimum_size = Vector2(0, 52)
layout_mode = 2
theme_override_font_sizes/font_size = 22
text = "Назад"

[node name="SettingsMenu" parent="CenterContainer" instance=ExtResource("2_settings")]
