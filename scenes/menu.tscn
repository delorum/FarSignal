theme_override_constants/separation = 18

[node name="Title" type="Label" parent="CenterContainer/MainMenu"]
layout_mode = 2
theme_override_colors/font_color = Color(0.345, 0.839, 0.961, 1)
theme_override_font_sizes/font_size = 52
text = "Far Signal"
