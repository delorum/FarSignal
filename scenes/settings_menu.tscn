[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/settings_menu.gd" id="1_settings"]

[node name="SettingsMenu" type="Control"]
auto_translate_mode = 2
visible = false
custom_minimum_size = Vector2(460, 420)
layout_mode = 3
anchors_preset = 0
script = ExtResource("1_settings")

[node name="SettingsScreen" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 18

[node name="Title" type="Label" parent="SettingsScreen"]
layout_mode = 2
theme_override_colors/font_color = Color(0.345, 0.839, 0.961, 1)
theme_override_font_sizes/font_size = 38
text = "Настройки"
horizontal_alignment = 1

[node name="TitleSeparator" type="Control" parent="SettingsScreen"]
custom_minimum_size = Vector2(0, 24)
layout_mode = 2

[node name="LanguageRow" type="HBoxContainer" parent="SettingsScreen"]
