theme_override_font_sizes/font_size = 20
text = "Язык"
vertical_alignment = 1

[node name="LanguageSelector" type="OptionButton" parent="SettingsScreen/LanguageRow"]
custom_minimum_size = Vector2(180, 52)
layout_mode = 2
