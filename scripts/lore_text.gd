extends RefCounted

const OBJECTIVE_TEXT := "Мы принимаем слабый сигнал с верхней стены - там есть выход.\n\nНайди его и проложи безопасный маршрут.\n\nСтанция расскажет подробности."
const STATION_INSTRUCTIONS := "1. Убивай охотников, забирай энергоядра и сдавай их на Станции 1.\n\n2. Исследуй клетки карты и сдавай накопленные очки исследования.\n\n3. Ищи мегаядра по координатам и возвращай их на Станцию 1.\n\n4. За ядра и исследование ты получаешь энергию. Чем опаснее враг или зона относительно твоего уровня, тем выше награда.\n\n5. На Станции 1 покупай здоровье, патроны и двери.\n\n6. Безопасная зона - это зеленые клетки пола, соединенные со Станцией 1 и отделенные дверями от остального лабиринта. Враги внутри нее не появляются.\n\n7. Чтобы расширить безопасную зону, исследуй проходы и поставь двери дальше от станции, перекрыв все выходы из присоединяемой области.\n\n8. Чем больше безопасная зона, тем меньше врагов остается на карте.\n\n9. На карте правой кнопкой мыши можно мгновенно перемещаться между проходимыми клетками безопасной зоны.\n\n10. Чем выше по карте, тем сильнее враги. Найди Станции 2 и 3: там за энергию можно улучшать урон, здоровье и боезапас."


static func objective_text() -> String:
	return TranslationServer.translate(OBJECTIVE_TEXT)


static func station_instructions() -> String:
	return TranslationServer.translate(STATION_INSTRUCTIONS)
